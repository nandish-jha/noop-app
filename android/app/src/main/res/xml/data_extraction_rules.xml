<?xml version="1.0" encoding="utf-8"?>
<!--
  NOOP is fully on-device. No cloud backup or device-transfer of the local WHOOP
  database / preferences — exclude everything from both Auto Backup and D2D transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
